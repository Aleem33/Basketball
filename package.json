{
  "name": "basketball-tournament-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev": "pnpm --filter @tournament/api... --filter @tournament/admin-web... build && pnpm --parallel --filter @tournament/api --filter @tournament/admin-web dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "test:coverage": "pnpm -r --if-present test:coverage",
    "validate": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "db:generate": "pnpm --filter @tournament/api prisma:generate",
    "db:migrate": "pnpm --filter @tournament/api prisma:migrate",
    "db:validate": "pnpm --filter @tournament/api prisma:validate",
    "bootstrap:admin": "pnpm --filter @tournament/api bootstrap:admin"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@types/node": "^26.1.1",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.5",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.39.0",
    "vitest": "^3.2.4"
  }
}
