# Docker Compose reference configuration. Replace every CHANGE_ME value before use.
POSTGRES_DB=tournament
POSTGRES_USER=tournament
POSTGRES_PASSWORD=CHANGE_ME_IN_SECRET_MANAGER

MINIO_ROOT_USER=CHANGE_ME_IN_SECRET_MANAGER
MINIO_ROOT_PASSWORD=CHANGE_ME_IN_SECRET_MANAGER
S3_BUCKET=tournament-media

JWT_ACCESS_SECRET=CHANGE_ME_RANDOM_MINIMUM_32_CHARACTERS
CSRF_SECRET=CHANGE_ME_DIFFERENT_RANDOM_MINIMUM_32_CHARACTERS
TOKEN_ENCRYPTION_KEY=CHANGE_ME_BASE64_ENCODED_32_BYTE_KEY

SMTP_HOST=CHANGE_ME_SMTP_HOST
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=CHANGE_ME_SMTP_USER
SMTP_PASSWORD=CHANGE_ME_IN_SECRET_MANAGER
SMTP_FROM=CHANGE_ME_VERIFIED_FROM_ADDRESS

APP_VERSION=0.1.0
APP_NAME=Tournament Platform
PRIMARY_COLOR=#174A7E
