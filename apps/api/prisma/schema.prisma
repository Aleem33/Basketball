model Game {
  id                String                @id @default(uuid()) @db.Uuid
  organizationId    String                @db.Uuid
  tournamentId      String                @db.Uuid
  divisionId        String?               @db.Uuid
  stageId           String?               @db.Uuid
  venueId           String?               @db.Uuid
  courtId           String?               @db.Uuid
  homeTeamId        String?               @db.Uuid
  awayTeamId        String?               @db.Uuid
  scheduledAt       DateTime              @db.Timestamptz(6)
  status            GameStatus            @default(DRAFT)
  currentPeriod     Int                   @default(0)
  regulationPeriods Int                  @default(4)
  homeScore         Int                   @default(0)
  awayScore         Int                   @default(0)
  version           Int                   @default(0)
  lastEventSequence Int                   @default(0)
  published         Boolean               @default(false)
  resultExplanation Json?                 
  forfeitWinnerId   String?               @db.Uuid
  startedAt         DateTime?             @db.Timestamptz(6)
  finalizedAt       DateTime?             @db.Timestamptz(6)
  createdAt         DateTime              @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime              @updatedAt @db.Timestamptz(6)
  deletedAt         DateTime?             @db.Timestamptz(6)
  organization      Organization          @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  tournament        Tournament            @relation(fields: [tournamentId], references: [id], onDelete: Restrict)
  division          Division?              @relation(fields: [divisionId], references: [id], onDelete: SetNull)
  stage             CompetitionStage?      @relation(fields: [stageId], references: [id], onDelete: SetNull)
  venue             Venue?                 @relation(fields: [venueId], references: [id], onDelete: SetNull)
  court             Court?                 @relation(fields: [courtId], references: [id], onDelete: SetNull)
  homeTeam          Team?                  @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: Restrict)
  awayTeam          Team?                  @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: Restrict)
  assignments       GameAssignment[]
  periods           GamePeriod[]
  scoreEvents       GameScoreEvent[]
  stateTransitions  GameStateTransition[]
  membershipRoles   MembershipRole[]
  sourceBracketLinks BracketMatchLink[]     @relation("SourceBracketGame")
  targetBracketLinks BracketMatchLink[]     @relation("TargetBracketGame")
  scoringLeases     ScoringLease[]
  invitations       Invitation[]

  @@index([organizationId, status, scheduledAt])
  @@index([tournamentId, published, scheduledAt])
  @@index([homeTeamId, scheduledAt])
  @@index([awayTeamId, scheduledAt])
  @@index([deletedAt])
}

