generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  LOCKED
  DELETION_REQUESTED
  DEACTIVATED
}

enum MembershipStatus {
  INVITED
  ACTIVE
  SUSPENDED
  LEFT
}

enum ScopeType {
  PLATFORM
  ORGANIZATION
  TOURNAMENT
  TEAM
  GAME
}

enum TournamentStatus {
  DRAFT
  REGISTRATION
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum CompetitionFormat {
  MANUAL
  SINGLE_ROUND_ROBIN
  DOUBLE_ROUND_ROBIN
  SINGLE_ELIMINATION
  GROUPS_THEN_KNOCKOUT
}

enum RosterStatus {
  DRAFT
  SUBMITTED
  CHANGES_REQUESTED
  APPROVED
  REJECTED
  ARCHIVED
}

enum SubmissionDecision {
  SUBMITTED
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

enum GameStatus {
  DRAFT
  SCHEDULED
  LIVE
  PAUSED
  FINAL
  POSTPONED
  CANCELLED
  ABANDONED
  FORFEITED
}

enum GameAssignmentType {
  SCOREKEEPER
  TOURNAMENT_MANAGER
  OFFICIAL
}

enum ScoreEventType {
  ADD_ONE
  ADD_TWO
  ADD_THREE
  CORRECTION
  TIMEOUT
  NOTE
}

enum StateTransitionType {
  GAME_STARTED
  PERIOD_STARTED
  PERIOD_PAUSED
  PERIOD_ENDED
  OVERTIME_STARTED
  GAME_ENDED
  GAME_FINALIZED
  GAME_REOPENED
  STATUS_CHANGED
}

enum TeamMemberRole {
  COACH
  TEAM_MANAGER
  ASSISTANT_COACH
}

enum PlayerPosition {
  POINT_GUARD
  SHOOTING_GUARD
  SMALL_FORWARD
  POWER_FORWARD
  CENTER
  UTILITY
}

enum Visibility {
  PRIVATE
  MEMBERS
  PUBLIC
}

enum RequestStatus {
  OPEN
  IN_REVIEW
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
}

enum MediaStatus {
  PENDING_UPLOAD
  AVAILABLE
  REPLACED
  DELETION_PENDING
  DELETED
  REJECTED
}

enum OutboxStatus {
  PENDING
  PROCESSING
  PUBLISHED
  FAILED
}

enum JobStatus {
  QUEUED
  ACTIVE
  SUCCEEDED
  FAILED
  DEAD_LETTER
}

enum NotificationChannel {
  EMAIL
  PUSH
  IN_APP
}

enum NotificationDeliveryStatus {
  PENDING
  SENT
  FAILED
  INVALID_TARGET
  SUPPRESSED
}

enum DevicePlatform {
  ANDROID
  IOS
  WEB
}

enum DataRequestType {
  EXPORT
  DELETION
}

model Organization {
  id                      String                    @id @default(uuid()) @db.Uuid
  name                    String                    @db.VarChar(160)
  slug                    String                    @unique @db.VarChar(80)
  settings                Json                      @default("{}")
  version                 Int                       @default(1)
  createdAt               DateTime                  @default(now()) @db.Timestamptz(6)
  updatedAt               DateTime                  @updatedAt @db.Timestamptz(6)
  archivedAt              DateTime?                 @db.Timestamptz(6)
  memberships             OrganizationMembership[]
  tournaments             Tournament[]
  leagues                 League[]
  seasons                 Season[]
  divisions               Division[]
  stages                  CompetitionStage[]
  ruleSets                CompetitionRuleSet[]
  venues                  Venue[]
  courts                  Court[]
  teams                   Team[]
  teamMemberships         TeamMembership[]
  players                 Player[]
  rosters                 Roster[]
  rosterSubmissions       RosterSubmission[]
  games                   Game[]
  gameAssignments         GameAssignment[]
  gamePeriods             GamePeriod[]
  scoreEvents             GameScoreEvent[]
  stateTransitions        GameStateTransition[]
  standings               Standing[]
  standingSnapshots       StandingSnapshot[]
  brackets                Bracket[]
  bracketRounds           BracketRound[]
  bracketLinks            BracketMatchLink[]
  announcements           Announcement[]
  correctionRequests      CorrectionRequest[]
  mediaAssets             MediaAsset[]
  auditLogs               AuditLog[]
  outboxEvents            OutboxEvent[]
  backgroundJobs          BackgroundJobRecord[]
  notificationPreferences NotificationPreference[]
  deviceRegistrations     DeviceRegistration[]
  notificationDeliveries  NotificationDelivery[]
  invitations             Invitation[]
  dataRequests            DataRequest[]
  scoringLeases           ScoringLease[]
  teamApplications        TeamApplication[]

  @@index([archivedAt])
}

model User {
  id                       String                    @id @default(uuid()) @db.Uuid
  email                    String                    @unique @db.VarChar(320)
  passwordHash             String                    @db.VarChar(255)
  status                   UserStatus                @default(PENDING_VERIFICATION)
  emailVerifiedAt          DateTime?                 @db.Timestamptz(6)
  platformSuperAdmin       Boolean                   @default(false)
  failedLoginCount         Int                       @default(0)
  lastFailedLoginAt        DateTime?                 @db.Timestamptz(6)
  lockedUntil              DateTime?                 @db.Timestamptz(6)
  passwordChangedAt        DateTime                  @default(now()) @db.Timestamptz(6)
  createdAt                DateTime                  @default(now()) @db.Timestamptz(6)
  updatedAt                DateTime                  @updatedAt @db.Timestamptz(6)
  deletedAt                DateTime?                 @db.Timestamptz(6)
  profile                  UserProfile?
  sessions                 Session[]
  verificationTokens       EmailVerificationToken[]
  passwordResetTokens      PasswordResetToken[]
  memberships              OrganizationMembership[]
  teamMemberships          TeamMembership[]
  rosterSubmissions        RosterSubmission[]        @relation("RosterSubmittedBy")
  rosterDecisions          RosterSubmission[]        @relation("RosterDecidedBy")
  gameAssignments          GameAssignment[]
  scoreEvents              GameScoreEvent[]
  stateTransitions         GameStateTransition[]
  manualStandingOverrides  Standing[]                @relation("StandingOverrideBy")
  favoritesTeams           FavoriteTeam[]
  favoritesTournaments     FavoriteTournament[]
  notificationPreferences  NotificationPreference[]
  deviceRegistrations      DeviceRegistration[]
  announcementsAuthored    Announcement[]
  correctionRequests       CorrectionRequest[]       @relation("CorrectionRequestedBy")
  correctionResolutions    CorrectionRequest[]       @relation("CorrectionResolvedBy")
  mediaAssetsCreated       MediaAsset[]              @relation("MediaCreatedBy")
  auditLogs                AuditLog[]
  impersonationAuditLogs   AuditLog[]                @relation("AuditImpersonatedUser")
  invitationsSent          Invitation[]              @relation("InvitationSentBy")
  dataRequests             DataRequest[]
  scoringLeases            ScoringLease[]
  teamApplicationDecisions TeamApplication[]         @relation("TeamApplicationDecidedBy")
  teamApplicationsSubmitted TeamApplication[]        @relation("TeamApplicationSubmittedBy")
  notificationDeliveries   NotificationDelivery[]

  @@index([status, lockedUntil])
  @@index([deletedAt])
}

model UserProfile {
  id                  String   @id @default(uuid()) @db.Uuid
  userId              String   @unique @db.Uuid
  displayName         String   @db.VarChar(120)
  givenName           String?  @db.VarChar(80)
  familyName          String?  @db.VarChar(80)
  timezone            String   @default("UTC") @db.VarChar(64)
  locale              String   @default("en") @db.VarChar(16)
  publicPlayerProfile Boolean  @default(false)
  createdAt           DateTime @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime @updatedAt @db.Timestamptz(6)
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  familyId         String    @db.Uuid
  refreshTokenHash String    @unique @db.VarChar(128)
  userAgentHash    String?   @db.VarChar(128)
  ipAddress        String?   @db.Inet
  rotationCounter  Int       @default(0)
  lastUsedAt       DateTime  @default(now()) @db.Timestamptz(6)
  expiresAt        DateTime  @db.Timestamptz(6)
  revokedAt        DateTime? @db.Timestamptz(6)
  revokeReason     String?   @db.VarChar(160)
  createdAt        DateTime  @default(now()) @db.Timestamptz(6)
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([familyId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique @db.VarChar(128)
  expiresAt DateTime  @db.Timestamptz(6)
  usedAt    DateTime? @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique @db.VarChar(128)
  expiresAt DateTime  @db.Timestamptz(6)
  usedAt    DateTime? @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model OrganizationMembership {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @db.Uuid
  userId         String           @db.Uuid
  status         MembershipStatus @default(INVITED)
  joinedAt       DateTime?        @db.Timestamptz(6)
  createdAt      DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime         @updatedAt @db.Timestamptz(6)
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  user           User             @relation(fields: [userId], references: [id], onDelete: Restrict)
  roles          MembershipRole[]

  @@unique([organizationId, userId])
  @@index([userId, status])
}

model Role {
  id          String           @id @default(uuid()) @db.Uuid
  key         String           @unique @db.VarChar(80)
  name        String           @db.VarChar(120)
  description String?          @db.VarChar(500)
  scopeType   ScopeType
  system      Boolean          @default(true)
  createdAt   DateTime         @default(now()) @db.Timestamptz(6)
  permissions RolePermission[]
  assignments MembershipRole[]
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  key         String           @unique @db.VarChar(120)
  description String           @db.VarChar(500)
  createdAt   DateTime         @default(now()) @db.Timestamptz(6)
  roles       RolePermission[]
}

model RolePermission {
  roleId       String     @db.Uuid
  permissionId String     @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model MembershipRole {
  id           String                 @id @default(uuid()) @db.Uuid
  membershipId String                 @db.Uuid
  roleId       String                 @db.Uuid
  tournamentId String?                @db.Uuid
  teamId       String?                @db.Uuid
  gameId       String?                @db.Uuid
  grantedAt    DateTime               @default(now()) @db.Timestamptz(6)
  expiresAt    DateTime?              @db.Timestamptz(6)
  membership   OrganizationMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  role         Role                   @relation(fields: [roleId], references: [id], onDelete: Restrict)
  tournament   Tournament?            @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team         Team?                  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  game         Game?                  @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([membershipId, roleId])
  @@index([tournamentId])
  @@index([teamId])
  @@index([gameId])
}

model League {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  name           String       @db.VarChar(160)
  slug           String       @db.VarChar(80)
  description    String?      @db.Text
  published      Boolean      @default(false)
  createdAt      DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @db.Timestamptz(6)
  archivedAt     DateTime?    @db.Timestamptz(6)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  seasons        Season[]
  tournaments    Tournament[]

  @@unique([organizationId, slug])
  @@index([organizationId, published, archivedAt])
}

model Season {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  leagueId       String       @db.Uuid
  name           String       @db.VarChar(160)
  startsAt       DateTime     @db.Timestamptz(6)
  endsAt         DateTime     @db.Timestamptz(6)
  published      Boolean      @default(false)
  createdAt      DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @db.Timestamptz(6)
  archivedAt     DateTime?    @db.Timestamptz(6)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  league         League       @relation(fields: [leagueId], references: [id], onDelete: Restrict)
  tournaments    Tournament[]
  rosters        Roster[]

  @@unique([leagueId, name])
  @@index([organizationId, startsAt, endsAt])
}

model Tournament {
  id              String            @id @default(uuid()) @db.Uuid
  organizationId  String            @db.Uuid
  leagueId        String?           @db.Uuid
  seasonId        String?           @db.Uuid
  name            String            @db.VarChar(180)
  slug            String            @db.VarChar(80)
  description     String?           @db.Text
  status          TournamentStatus  @default(DRAFT)
  registrationAt  DateTime?         @db.Timestamptz(6)
  registrationEnd DateTime?         @db.Timestamptz(6)
  startsAt        DateTime           @db.Timestamptz(6)
  endsAt          DateTime           @db.Timestamptz(6)
  timezone        String             @default("UTC") @db.VarChar(64)
  published       Boolean            @default(false)
  version         Int                @default(1)
  createdAt       DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime           @updatedAt @db.Timestamptz(6)
  archivedAt      DateTime?          @db.Timestamptz(6)
  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  league          League?            @relation(fields: [leagueId], references: [id], onDelete: SetNull)
  season          Season?            @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  divisions       Division[]
  teams           TournamentTeam[]
  rosters         Roster[]
  games           Game[]
  announcements   Announcement[]
  favorites       FavoriteTournament[]
  membershipRoles MembershipRole[]
  invitations     Invitation[]
  teamApplications TeamApplication[]

  @@unique([organizationId, slug])
  @@index([organizationId, published, status, startsAt])
  @@index([archivedAt])
}

model Division {
  id             String             @id @default(uuid()) @db.Uuid
  organizationId String             @db.Uuid
  tournamentId   String             @db.Uuid
  name           String             @db.VarChar(120)
  sortOrder      Int                @default(0)
  published      Boolean            @default(false)
  createdAt      DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime           @updatedAt @db.Timestamptz(6)
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  tournament     Tournament         @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  stages         CompetitionStage[]
  games          Game[]

  @@unique([tournamentId, name])
  @@index([organizationId, published])
}

model CompetitionStage {
  id             String             @id @default(uuid()) @db.Uuid
  organizationId String             @db.Uuid
  divisionId     String             @db.Uuid
  name           String             @db.VarChar(120)
  format         CompetitionFormat
  sequence       Int
  published      Boolean            @default(false)
  createdAt      DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime           @updatedAt @db.Timestamptz(6)
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  division       Division           @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  ruleSet        CompetitionRuleSet?
  games          Game[]
  standings      Standing[]
  snapshots      StandingSnapshot[]
  brackets       Bracket[]

  @@unique([divisionId, sequence])
  @@index([organizationId, published])
}

model CompetitionRuleSet {
  id                   String             @id @default(uuid()) @db.Uuid
  organizationId       String             @db.Uuid
  stageId               String             @unique @db.Uuid
  regulationPeriods    Int
  periodDurationSeconds Int
  overtimeDurationSeconds Int
  allowDraws           Boolean            @default(false)
  winPoints            Int                @default(2)
  lossPoints           Int                @default(0)
  drawPoints           Int                @default(1)
  forfeitWinPoints     Int                @default(2)
  forfeitScoreFor      Int                @default(20)
  forfeitScoreAgainst  Int                @default(0)
  tieBreakers          Json
  advancementRules     Json               @default("{}")
  version              Int                @default(1)
  createdAt            DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime           @updatedAt @db.Timestamptz(6)
  organization         Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  stage                CompetitionStage   @relation(fields: [stageId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model Venue {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  name           String       @db.VarChar(160)
  addressLine1   String       @db.VarChar(180)
  addressLine2   String?      @db.VarChar(180)
  city           String       @db.VarChar(100)
  region         String?      @db.VarChar(100)
  postalCode     String?      @db.VarChar(32)
  countryCode    String       @db.Char(2)
  latitude       Decimal?     @db.Decimal(9, 6)
  longitude      Decimal?     @db.Decimal(9, 6)
  published      Boolean      @default(false)
  createdAt      DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @db.Timestamptz(6)
  archivedAt     DateTime?    @db.Timestamptz(6)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  courts         Court[]
  games          Game[]

  @@unique([organizationId, name])
  @@index([organizationId, published, archivedAt])
}

model Court {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  venueId        String       @db.Uuid
  name           String       @db.VarChar(100)
  published      Boolean      @default(false)
  createdAt      DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @db.Timestamptz(6)
  archivedAt     DateTime?    @db.Timestamptz(6)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  venue          Venue        @relation(fields: [venueId], references: [id], onDelete: Cascade)
  games          Game[]

  @@unique([venueId, name])
  @@index([organizationId, published, archivedAt])
}

model Team {
  id               String             @id @default(uuid()) @db.Uuid
  organizationId   String             @db.Uuid
  name             String             @db.VarChar(160)
  shortName        String?            @db.VarChar(32)
  description      String?            @db.Text
  logoAssetId      String?            @unique @db.Uuid
  published        Boolean            @default(false)
  version          Int                @default(1)
  createdAt        DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime           @updatedAt @db.Timestamptz(6)
  archivedAt       DateTime?          @db.Timestamptz(6)
  organization     Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  logoAsset        MediaAsset?        @relation("TeamLogo", fields: [logoAssetId], references: [id], onDelete: SetNull)
  memberships      TeamMembership[]
  players          Player[]
  tournaments      TournamentTeam[]
  rosters          Roster[]
  homeGames        Game[]             @relation("HomeTeam")
  awayGames        Game[]             @relation("AwayTeam")
  scoreEvents      GameScoreEvent[]
  standings        Standing[]
  favorites        FavoriteTeam[]
  membershipRoles  MembershipRole[]
  teamApplications TeamApplication[]
  invitations      Invitation[]

  @@unique([organizationId, name])
  @@index([organizationId, published, archivedAt])
}

model TournamentTeam {
  tournamentId String     @db.Uuid
  teamId       String     @db.Uuid
  seed         Int?
  approvedAt   DateTime?  @db.Timestamptz(6)
  createdAt    DateTime   @default(now()) @db.Timestamptz(6)
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team         Team       @relation(fields: [teamId], references: [id], onDelete: Restrict)

  @@id([tournamentId, teamId])
  @@index([teamId])
}

model TeamMembership {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @db.Uuid
  teamId         String           @db.Uuid
  userId         String           @db.Uuid
  role           TeamMemberRole
  active         Boolean          @default(true)
  startsAt       DateTime         @default(now()) @db.Timestamptz(6)
  endsAt         DateTime?        @db.Timestamptz(6)
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  team           Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([teamId, userId, role])
  @@index([organizationId, userId, active])
}

model Player {
  id               String         @id @default(uuid()) @db.Uuid
  organizationId   String         @db.Uuid
  teamId           String         @db.Uuid
  givenName        String         @db.VarChar(80)
  familyName       String         @db.VarChar(80)
  dateOfBirth      DateTime?      @db.Date
  position         PlayerPosition?
  defaultJersey    Int?
  publicVisibility Visibility     @default(PRIVATE)
  version          Int            @default(1)
  createdAt        DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime       @updatedAt @db.Timestamptz(6)
  archivedAt       DateTime?      @db.Timestamptz(6)
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  team             Team           @relation(fields: [teamId], references: [id], onDelete: Restrict)
  rosters          RosterPlayer[]

  @@index([organizationId, teamId, archivedAt])
}

model Roster {
  id             String             @id @default(uuid()) @db.Uuid
  organizationId String             @db.Uuid
  teamId         String             @db.Uuid
  tournamentId   String             @db.Uuid
  seasonId       String?            @db.Uuid
  status         RosterStatus       @default(DRAFT)
  visibility     Visibility         @default(PRIVATE)
  version        Int                @default(1)
  createdAt      DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime           @updatedAt @db.Timestamptz(6)
  archivedAt     DateTime?          @db.Timestamptz(6)
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  team           Team               @relation(fields: [teamId], references: [id], onDelete: Restrict)
  tournament     Tournament         @relation(fields: [tournamentId], references: [id], onDelete: Restrict)
  season         Season?            @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  players        RosterPlayer[]
  submissions    RosterSubmission[]

  @@unique([teamId, tournamentId])
  @@index([organizationId, status, archivedAt])
}

model RosterPlayer {
  id           String   @id @default(uuid()) @db.Uuid
  rosterId     String   @db.Uuid
  playerId     String   @db.Uuid
  jerseyNumber Int
  position     PlayerPosition?
  captain      Boolean  @default(false)
  addedAt      DateTime @default(now()) @db.Timestamptz(6)
  roster       Roster   @relation(fields: [rosterId], references: [id], onDelete: Cascade)
  player       Player   @relation(fields: [playerId], references: [id], onDelete: Restrict)

  @@unique([rosterId, playerId])
  @@unique([rosterId, jerseyNumber])
}

model RosterSubmission {
  id             String             @id @default(uuid()) @db.Uuid
  organizationId String             @db.Uuid
  rosterId       String             @db.Uuid
  submittedById  String             @db.Uuid
  decidedById    String?            @db.Uuid
  decision       SubmissionDecision @default(SUBMITTED)
  message        String?            @db.Text
  submittedAt    DateTime           @default(now()) @db.Timestamptz(6)
  decidedAt      DateTime?          @db.Timestamptz(6)
