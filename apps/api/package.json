{
  "name": "@tournament/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build && node scripts/copy-generated-client.mjs",
    "dev": "nest start --watch",
    "start": "node dist/src/main.js",
    "start:worker": "node dist/src/worker.js",
    "lint": "eslint src test scripts --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --exclude 'test/integration/**'",
    "test:coverage": "vitest run --coverage --exclude 'test/integration/**'",
    "test:integration": "vitest run test/integration",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:migrate": "prisma migrate deploy",
    "openapi:generate": "tsc -p tsconfig.json && node scripts/copy-generated-client.mjs && node dist/scripts/generate-openapi.js",
    "bootstrap:admin": "tsx scripts/bootstrap-admin.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.850.0",
    "@aws-sdk/s3-request-presigner": "^3.850.0",
    "@nestjs/common": "^11.1.5",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.5",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.1.5",
    "@nestjs/platform-socket.io": "^11.1.5",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/websockets": "^11.1.5",
    "@tournament/config": "workspace:*",
    "@tournament/contracts": "workspace:*",
    "@tournament/shared-types": "workspace:*",
    "@tournament/validation": "workspace:*",
    "argon2": "^0.43.1",
    "bullmq": "^5.56.7",
    "cookie-parser": "^1.4.7",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.1",
    "nanoid": "^5.1.5",
    "nodemailer": "^9.0.3",
    "pino": "^9.7.0",
    "pino-http": "^10.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/testing": "^11.1.5",
    "@prisma/client": "6.13.0",
    "@testcontainers/postgresql": "^11.5.1",
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.0",
    "@types/nodemailer": "^8.0.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.32.0",
    "prettier": "^3.6.2",
    "prisma": "6.13.0",
    "supertest": "^7.1.4",
    "tsx": "^4.20.3",
    "typescript": "^7.0.2",
    "vitest": "^3.2.4"
  }
}
